# ── Firebase (client, chaves públicas) ──────────────────────────────
# Firebase Console → Project Settings → General → Seus apps → SDK setup
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# ── Firebase Admin (backend, segredo — NUNCA expor com prefixo VITE_) ──
# Firebase Console → Project Settings → Service accounts → Generate new private key
# Cola o conteúdo do JSON inteiro numa linha só (string), entre aspas simples
FIREBASE_SERVICE_ACCOUNT=

# ── Neon (Postgres) ──────────────────────────────────────────────────
# Neon Console → seu projeto → Connection Details → Connection string (pooled)
DATABASE_URL=

# ── Anthropic (Claude API) ───────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=
